     }
+#endif
+}
+
+// TF32 WMMA is only available on Ampere (compute capability 8.0) and newer.
+// Keep the kernel in all builds so a single source can target older GPUs, but
+// never launch its empty pre-Ampere specialization.
+bool cuda_tf32_supported() {
+    static thread_local int cached_device = -1;
+    static thread_local bool cached_supported = false;
+    int device = -1;
+    if (cudaGetDevice(&device) != cudaSuccess) return false;
+    if (device != cached_device) {
+        int major = 0;
+        cached_supported =
+            cudaDeviceGetAttribute(&major, cudaDevAttrComputeCapabilityMajor, device) == cudaSuccess &&
+            major >= 8;
+        cached_device = device;
+    }
+    return cached_supported;
 }
 
