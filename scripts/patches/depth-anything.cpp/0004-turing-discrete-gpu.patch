diff --git a/src/cuda_head_kernels.cu b/src/cuda_head_kernels.cu
index 299a1d4..e134584 100644
--- a/src/cuda_head_kernels.cu
+++ b/src/cuda_head_kernels.cu
@@ -196,6 +196,7 @@ __global__ void k_conv3x3_wmma(const float* __restrict__ X, const float* __restr
                                const float* __restrict__ B, const float* __restrict__ R,
                                float* __restrict__ Y,
                                int W, int H, int IC, int OC, int flags) {
+#if defined(__CUDA_ARCH__) && __CUDA_ARCH__ >= 800
     using namespace nvcuda;
     const int P = W * H;
     const int K = IC * 9;
@@ -262,6 +263,25 @@ __global__ void k_conv3x3_wmma(const float* __restrict__ X, const float* __restr
